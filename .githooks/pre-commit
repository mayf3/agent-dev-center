#!/bin/bash
# pre-commit — Secret Detection Hook
# 检测被暂存的文件中是否包含潜在的凭据/密钥泄露
#
# 功能：
#   1. 检测常见密钥模式（API key, token, password, secret, private key）
#   2. 检测 .env、.token、credentials 等敏感文件
#   3. 检测 base64 编码的长密码（>40字符，类密钥）
#
# 安装：git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔍 执行预提交密钥检测..."

# 获取暂存的文件列表
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "✅ 无暂存文件，跳过"
  exit 0
fi

HAS_ISSUES=0

# 敏感文件模式（禁止提交）
SENSITIVE_FILES_PATTERNS=(
  "\.env$"
  "\.env\.local$"
  "\.env\.production$"
  "\.env\.development$"
  "\.adc-token"
  "\.token$"
  "credential"
  "secret.*\.json$"
  "private.*\.key$"
  "id_rsa"
  "id_ed25519"
)

# 敏感内容模式（基于 gitleaks 和 trufflehog 规则精简）
SECRET_PATTERNS=(
  # AWS Access Key
  'AKIA[0-9A-Z]{16}'
  # GitHub / GitLab Token
  '(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{36}'
  # Slack Token
  'xox[baprs]-[0-9]{12}-[0-9]{12}-[0-9]{12}-[a-z0-9]{32}'
  # Google API Key
  'AIza[0-9A-Za-z\-_]{35}'
  # Generic password/secret assign
  '(password|passwd|pwd|secret|api[_-]?key|token|jwt)[[:space:]]*[:=][[:space:]]*['"'"'\"].+['"'"'\"']
  # JWT-like tokens
  'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}'
  # Private key
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
)

# 检查敏感文件名
for file in $STAGED_FILES; do
  for pattern in "${SENSITIVE_FILES_PATTERNS[@]}"; do
    if echo "$file" | grep -qiE "$pattern"; then
      echo -e "${RED}❌ 禁止提交敏感文件: $file${NC}"
      HAS_ISSUES=1
    fi
  done
done

# 检查暂存内容中的密钥模式
for file in $STAGED_FILES; do
  # 跳过二进制文件
  if [ -f "$file" ] && file --mime-encoding "$file" 2>/dev/null | grep -q "binary"; then
    continue
  fi

  # 获取该文件的暂存内容中的差异部分（新增行）
  git diff --cached "$file" 2>/dev/null | grep '^+' | grep -v '^+++' | sed 's/^+//' > /tmp/.precommit_scan_$$
  
  if [ ! -s /tmp/.precommit_scan_$$ ]; then
    rm -f /tmp/.precommit_scan_$$
    continue
  fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    if grep -qE "$pattern" /tmp/.precommit_scan_$$ 2>/dev/null; then
      echo -e "${YELLOW}⚠️  文件 $file 中可能包含密钥信息（匹配: $pattern）${NC}"
      echo "   请检查并确认后使用 --no-verify 强制提交（仅用于测试目的）"
      grep -nE "$pattern" /tmp/.precommit_scan_$$ 2>/dev/null | head -3 | while read -r line; do
        echo -e "${YELLOW}   → 可疑行: $(echo "$line" | sed 's/./*/g' | head -c 40)...${NC}"
      done
      HAS_ISSUES=1
    fi
  done

  rm -f /tmp/.precommit_scan_$$
done

if [ $HAS_ISSUES -eq 1 ]; then
  echo ""
  echo -e "${RED}❌ 密钥检测未通过，提交已阻止。${NC}"
  echo "   如需强制提交（不推荐），执行: git commit --no-verify"
  exit 1
fi

echo "✅ 密钥检测通过"
exit 0
