/* pages/requirement-detail/index.wxss */
.page { padding-bottom: 40rpx; }

.detail-header { text-align: center; }
.header-tags { display: flex; justify-content: center; gap: 12rpx; margin-bottom: 16rpx; }
.detail-title { font-size: 34rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 12rpx; }
.header-meta { font-size: 24rpx; color: #999; }

.action-bar { display: flex; gap: 16rpx; padding: 0 24rpx 16rpx; }
.action-bar button { flex: 1; font-size: 26rpx; padding: 16rpx; }

.info-value-danger { color: #ff4d4f; }

/* 任务项 */
.task-item { padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; position: relative; }
.task-item:last-child { border-bottom: none; }
.task-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8rpx; }
.task-title { font-size: 26rpx; font-weight: 500; flex: 1; margin-right: 12rpx; }
.task-meta { font-size: 22rpx; color: #999; }
.task-tip { font-size: 20rpx; color: #1677ff; margin-top: 8rpx; display: block; }

/* 报告项 */
.report-item { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.report-item:last-child { border-bottom: none; }
.report-title { font-size: 26rpx; font-weight: 500; margin-bottom: 4rpx; }
.report-meta { font-size: 22rpx; color: #999; }

/* 弹窗 */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; justify-content: center; align-items: center; z-index: 300; }
.modal-content { background: #fff; border-radius: 24rpx; padding: 40rpx; width: 640rpx; max-width: 90%; }
.modal-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; text-align: center; }
.modal-actions { display: flex; gap: 20rpx; margin-top: 28rpx; }
.modal-actions button { flex: 1; font-size: 26rpx; padding: 18rpx; }
.btn-cancel { background: #f5f5f5; color: #666; border: none; border-radius: 12rpx; text-align: center; }
.btn-cancel::after { border: none; }
