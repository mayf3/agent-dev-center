{"success":true,"content":"generator client {\n  provider = \"prisma-client-js\"\n}\n\ndatasource db {\n  provider = \"postgresql\"\n  url      = env(\"DATABASE_URL\")\n}\n\nmodel User {\n  id                    String                @id @default(uuid()) @db.Uuid\n  name                  String\n  email                 String                @unique\n  password              String\n  role                  UserRole              @default(requester)\n  createdAt             DateTime              @default(now())\n  agentId               String?               @unique\n  permissions           Json                  @default(\"[]\")\n  bio                   String?\n  phone                 String?\n  avatar                String?\n  department            String?\n  title                 String?\n  employeeNo            String?               @unique\n  onboardingDate        DateTime?\n  managerId             String?               @db.Uuid\n  internalRole          InternalRole?         @map(\"internal_role\")\n  okrRole               OkrRole               @default(okr_member) @map(\"okr_role\")\n  mustChangePassword    Boolean               @default(true) @map(\"must_change_password\")\n  enabled               Boolean               @default(true)\n  passwordChangedAt     DateTime?             @map(\"password_changed_at\")\n  lastLoginAt           DateTime?             @map(\"last_login_at\")\n  roles                 String[]              @default([]) @map(\"roles\")\n  okrRole               String                @default(\"okr_member\")\n  marketplaceAgents     MarketplaceAgent[]    @relation(\"MarketplaceAgentOwner\")\n  linkedAgent           MarketplaceAgent?     @relation(\"AgentUserLink\")\n  marketplaceTasks      MarketplaceTask[]     @relation(\"MarketplaceRequester\")\n  ownedProjects         Project[]             @relation(\"ProjectOwner\")\n  comments              RequirementComment[]  @relation(\"CommentAuthor\")\n  submittedReports      RequirementReport[]   @relation(\"ReportSubmitter\")\n  requirementRevisions  RequirementRevision[] @relation(\"RequirementRevisionOperator\")\n  assignedRequirements  Requirement[]         @relation(\"AssigneeRequirements\")\n  requestedRequirements Requirement[]         @relation(\"RequesterRequirements\")\n  manager               User?                 @relation(\"UserManager\", fields: [managerId], references: [id])\n  directReports         User[]                @relation(\"UserManager\")\n\n  @@index([lastLoginAt])\n  @@map(\"users\")\n}\n\nmodel AuditLog {\n  id         String   @id @default(uuid()) @db.Uuid\n  action     String\n  targetType String\n  targetId   String   @db.Uuid\n  actorId    String   @db.Uuid\n  actorName  String\n  details    Json?\n  createdAt  DateTime @default(now())\n\n  @@index([createdAt])\n  @@index([targetType, targetId])\n  @@index([actorId])\n  @@map(\"audit_logs\")\n}\n\nmodel PasswordPolicy {\n  id                   String   @id @default(uuid()) @db.Uuid\n  name                 String   @unique @default(\"default\")\n  minLength            Int      @default(8)\n  requireUppercase     Boolean  @default(true) @map(\"require_uppercase\")\n  requireLowercase     Boolean  @default(true) @map(\"require_lowercase\")\n  requireNumber        Boolean  @default(true) @map(\"require_number\")\n  requireSpecial       Boolean  @default(false) @map(\"require_special\")\n  expiresInDays        Int?     @map(\"expires_in_days\")\n  forceChangeCycleDays Int?     @map(\"force_change_cycle_days\")\n  isDefault            Boolean  @default(true) @map(\"is_default\")\n  createdAt            DateTime @default(now())\n  updatedAt            DateTime @updatedAt\n\n  @@map(\"password_policies\")\n}\n\nmodel Requirement {\n  id                  String                @id @default(uuid()) @db.Uuid\n  title               String\n  description         String\n  priority            RequirementPriority   @default(P2)\n  requester           String\n  department          String\n  assignee            String?\n  dueDate             DateTime?\n  attachment          String?\n  rejectReason        String?\n  createdAt           DateTime              @default(now())\n  updatedAt           DateTime              @updatedAt\n  requesterId         String?               @db.Uuid\n  assigneeId          String?               @db.Uuid\n  notes               String?\n  pmApprovedAt        DateTime?             @map(\"pm_approved_at\")\n  pmApprovedBy        String?               @map(\"pm_approved_by\")\n  gitHash             String?\n  deployVersion       String?\n  type                RequirementType       @default(FEATURE)\n  tags                String[]              @default([])\n  workflowId          String?               @db.Uuid\n  currentStep         String?\n  branch              String?\n  repoPath            String?\n  dependsOnIds        String[]              @default([]) @map(\"depends_on_ids\")\n  blockedBy           String[]              @default([]) @map(\"blocked_by\")\n  projectId           String?               @db.Uuid\n  status              String                @default(\"pending\")\n  postmortems         Postmortem[]\n  comments            RequirementComment[]  @relation(\"CommentRequirement\")\n  reports             RequirementReport[]\n  revisions           RequirementRevision[]\n  assigneeUser        User?                 @relation(\"AssigneeRequirements\", fields: [assigneeId], references: [id])\n  project             Project?              @relation(\"RequirementProject\", fields: [projectId], references: [id])\n  requesterUser       User?                 @relation(\"RequesterRequirements\", fields: [requesterId], references: [id])\n  workflow            WorkflowTemplate?     @relation(fields: [workflowId], references: [id])\n  serviceLinks        ServiceRequirement[]\n  tasks               Task[]\n  workflowTransitions WorkflowTransition[]\n\n  @@index([currentStep])\n  @@index([priority])\n  @@index([type])\n  @@index([requester])\n  @@index([requesterId])\n  @@index([assignee])\n  @@index([assigneeId])\n  @@index([projectId])\n  @@map(\"requirements\")\n}\n\nmodel Task {\n  id            String      @id @default(uuid()) @db.Uuid\n  requirementId String      @db.Uuid\n  title         String\n  description   String\n  agentType     String\n  status        TaskStatus  @default(todo)\n  createdAt     DateTime    @default(now())\n  updatedAt     DateTime    @updatedAt\n  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)\n\n  @@index([requirementId])\n  @@index([status])\n  @@index([agentType])\n  @@map(\"tasks\")\n}\n\nmodel RequirementRevision {\n  id            String              @id @default(uuid()) @db.Uuid\n  requirementId String              @db.Uuid\n  title         String\n  description   String\n  priority      RequirementPriority\n  status        RequirementStatus\n  requester     String\n  department    String\n  assignee      String?\n  dueDate       DateTime?\n  attachment    String?\n  revisionNote  String?\n  operatorId    String?             @db.Uuid\n  createdAt     DateTime            @default(now())\n  operator      User?               @relation(\"RequirementRevisionOperator\", fields: [operatorId], references: [id])\n  requirement   Requirement         @relation(fields: [requirementId], references: [id], onDelete: Cascade)\n\n  @@index([requirementId])\n  @@index([createdAt])\n  @@map(\"requirement_revisions\")\n}\n\nmodel RequirementReport {\n  id              String       @id @default(uuid()) @db.Uuid\n  requirementId   String       @db.Uuid\n  reportType      ReportType\n  content         Json\n  submittedBy     String\n  submittedById   String?      @db.Uuid\n  status          ReportStatus @default(pending)\n  reviewComment   String?\n  reviewedAt      DateTime?\n  createdAt       DateTime     @default(now())\n  updatedAt       DateTime     @updatedAt\n  qaBypass        Boolean      @default(false) @map(\"qa_bypass\")\n  qaBypassReason  String?      @map(\"qa_bypass_reason\")\n  qaBypassAt      DateTime?    @map(\"qa_bypass_at\")\n  qaBypassBy      String?      @map(\"qa_bypass_by\")\n  qaReviewedAt    DateTime?    @map(\"qa_reviewed_at\")\n  qaReviewedBy    String?      @map(\"qa_reviewed_by\")\n  workflowStep    String?      @map(\"workflow_step\")\n  workflowStep    String?\n  requirement     Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)\n  submittedByUser User?        @relation(\"ReportSubmitter\", fields: [submittedById], references: [id])\n\n  @@unique([requirementId, reportType, workflowStep])\n  @@unique([requirementId, reportType, workflowStep], map: \"idx_requirement_reports_unique\")\n  @@unique([requirementId, reportType, workflowStep])\n  @@index([requirementId])\n  @@index([reportType])\n  @@index([submittedBy])\n  @@index([status])\n  @@map(\"requirement_reports\")\n}\n\nmodel Notification {\n  id           String   @id @default(uuid()) @db.Uuid\n  userId       String?  @db.Uuid\n  type         String\n  title        String\n  content      Json\n  relatedReqId String?  @db.Uuid\n  isRead       Boolean  @default(false)\n  createdAt    DateTime @default(now())\n\n  @@index([userId])\n  @@index([isRead])\n  @@index([type])\n  @@index([createdAt])\n  @@map(\"notifications\")\n}\n\nmodel MarketplaceAgent {\n  id                 String                 @id @default(uuid()) @db.Uuid\n  name               String                 @unique\n  displayName        String\n  description        String\n  avatar             String?\n  capabilities       Json                   @default(\"[]\")\n  apiEndpoint        String?\n  status             MarketplaceAgentStatus @default(active)\n  notificationType   String                 @default(\"polling\")\n  feishuWebhookUrl   String?\n  tags               String[]               @default([])\n  lastHeartbeatAt    DateTime?\n  agentToken         String?                @unique\n  ownerId            String?                @db.Uuid\n  openclawAgentId    String?\n  registrationSource String?\n  registrationGroup  String?\n  mergedInto         String?                @db.Uuid\n  mergedAt           DateTime?\n  createdAt          DateTime               @default(now())\n  updatedAt          DateTime               @updatedAt\n  userId             String?                @unique @map(\"user_id\") @db.Uuid\n  accessTokens       AgentAccessToken[]\n  goalCard           AgentGoalCard?\n  dailyLogs          DailyLog[]\n  owner              User?                  @relation(\"MarketplaceAgentOwner\", fields: [ownerId], references: [id])\n  user               User?                  @relation(\"AgentUserLink\", fields: [userId], references: [id])\n  tasks              MarketplaceTask[]\n  weeklyReports      WeeklyReport[]\n\n  @@index([status])\n  @@index([ownerId])\n  @@index([userId])\n  @@map(\"marketplace_agents\")\n}\n\nmodel MarketplaceTask {\n  id              String                   @id @default(uuid()) @db.Uuid\n  agentId         String                   @db.Uuid\n  requesterId     String?                  @db.Uuid\n  requesterName   String\n  title           String\n  description     String\n  input           Json?\n  priority        MarketplacePriority      @default(normal)\n  status          MarketplaceTaskStatus    @default(pending)\n  deadline        DateTime?\n  startedAt       DateTime?\n  completedAt     DateTime?\n  errorMsg        String?\n  notifiedAt      DateTime?\n  executionTimeMs Int?\n  tokensUsed      Int?\n  createdAt       DateTime                 @default(now())\n  updatedAt       DateTime                 @updatedAt\n  deliverables    MarketplaceDeliverable[]\n  agent           MarketplaceAgent         @relation(fields: [agentId], references: [id])\n  requester       User?                    @relation(\"MarketplaceRequester\", fields: [requesterId], references: [id])\n\n  @@index([agentId])\n  @@index([status])\n  @@index([requesterId])\n  @@map(\"marketplace_tasks\")\n}\n\nmodel MarketplaceDeliverable {\n  id        String          @id @default(uuid()) @db.Uuid\n  taskId    String          @db.Uuid\n  type      DeliverableType\n  title     String?\n  content   String\n  metadata  Json?\n  createdAt DateTime        @default(now())\n  task      MarketplaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)\n\n  @@index([taskId])\n  @@map(\"marketplace_deliverables\")\n}\n\nmodel AgentAccessToken {\n  id         String           @id @default(uuid()) @db.Uuid\n  agentId    String           @db.Uuid\n  token      String           @unique\n  name       String           @default(\"default\")\n  lastUsedAt DateTime?\n  createdAt  DateTime         @default(now())\n  expiresAt  DateTime?\n  agent      MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)\n\n  @@index([agentId])\n  @@index([token])\n  @@map(\"agent_access_tokens\")\n}\n\nmodel Service {\n  id             String               @id @default(uuid()) @db.Uuid\n  name           String               @unique\n  displayName    String\n  description    String\n  port           Int?\n  localUrl       String?\n  remoteUrl      String?\n  techStack      String[]             @default([])\n  owner          String?\n  gitRepo        String?\n  database       String?\n  status         ServiceStatus        @default(unknown)\n  version        String?\n  lastDeployedAt DateTime?\n  createdAt      DateTime             @default(now())\n  updatedAt      DateTime             @updatedAt\n  requirements   ServiceRequirement[]\n\n  @@index([status])\n  @@index([owner])\n  @@map(\"services\")\n}\n\nmodel ServiceRequirement {\n  id            String      @id @default(uuid()) @db.Uuid\n  serviceId     String      @db.Uuid\n  requirementId String      @db.Uuid\n  relationType  String      @default(\"related\")\n  createdAt     DateTime    @default(now())\n  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)\n  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)\n\n  @@unique([serviceId, requirementId])\n  @@index([serviceId])\n  @@index([requirementId])\n  @@map(\"service_requirements\")\n}\n\nmodel AgentGoalCard {\n  id                 String           @id @default(uuid()) @db.Uuid\n  agentId            String           @unique @db.Uuid\n  pipeline           PipelineName\n  layer              GoalLayer        @default(mainline)\n  upstreamAgentIds   String[]         @default([])\n  downstreamAgentIds String[]         @default([])\n  longTermDirection  String\n  monthlyGoals       Json             @default(\"[]\")\n  selfCheckCriteria  String\n  pushedMonths       String[]         @default([])\n  status             GoalStatus       @default(active)\n  lastReviewedAt     DateTime?\n  lastReviewedBy     String?\n  createdAt          DateTime         @default(now())\n  updatedAt          DateTime         @updatedAt\n  agent              MarketplaceAgent @relation(fields: [agentId], references: [id])\n  revisions          GoalRevision[]\n\n  @@index([pipeline])\n  @@index([status])\n  @@map(\"agent_goal_cards\")\n}\n\nmodel GoalRevision {\n  id                String        @id @default(uuid()) @db.Uuid\n  goalCardId        String        @db.Uuid\n  longTermDirection String\n  monthlyGoals      Json\n  selfCheckCriteria String\n  pipeline          PipelineName\n  changeNote        String\n  changedBy         String\n  changedById       String?       @db.Uuid\n  createdAt         DateTime      @default(now())\n  goalCard          AgentGoalCard @relation(fields: [goalCardId], references: [id], onDelete: Cascade)\n\n  @@index([goalCardId])\n  @@index([createdAt])\n  @@map(\"goal_revisions\")\n}\n\nmodel WeeklyReport {\n  id            String             @id @default(uuid()) @db.Uuid\n  agentId       String             @db.Uuid\n  week          String\n  content       String\n  summary       String             @default(\"\")\n  nextWeekPlan  String             @default(\"\")\n  blockers      String             @default(\"\")\n  submittedBy   String             @default(\"\")\n  submittedAt   DateTime?\n  status        WeeklyReportStatus @default(draft)\n  reviewedBy    String?\n  reviewedAt    DateTime?\n  reviewComment String?\n  createdAt     DateTime           @default(now())\n  updatedAt     DateTime           @updatedAt\n  agent         MarketplaceAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)\n\n  @@unique([agentId, week])\n  @@index([agentId])\n  @@index([week])\n  @@index([status])\n  @@map(\"weekly_reports\")\n}\n\nmodel Postmortem {\n  id                 String           @id @default(uuid()) @db.Uuid\n  requirementId      String?          @db.Uuid\n  title              String\n  phenomenon         String\n  rootCause          String\n  whyExistingProcess String\n  longTermPrinciple  String\n  preventionMeasures String\n  createdAt          DateTime         @default(now())\n  updatedAt          DateTime         @updatedAt\n  responsiblePerson  String\n  status             PostmortemStatus @default(pending)\n  requirement        Requirement?     @relation(fields: [requirementId], references: [id])\n\n  @@index([status])\n  @@index([responsiblePerson])\n  @@index([requirementId])\n  @@map(\"postmortems\")\n}\n\nmodel Identity {\n  id                String        @id @default(uuid()) @db.Uuid\n  type              EntityType\n  displayName       String\n  avatar            String?\n  description       String\n  longTermDirection String\n  monthlyGoals      Json          @default(\"[]\")\n  capabilities      Json          @default(\"[]\")\n  pipeline          PipelineName?\n  layer             GoalLayer?\n  agentId           String?       @unique\n  ownerId           String?       @map(\"owner_id\")\n  agentType         String?\n  userId            String?       @unique\n  status            String        @default(\"active\")\n  createdAt         DateTime      @default(now())\n  updatedAt         DateTime      @updatedAt\n\n  @@index([type])\n  @@index([pipeline])\n  @@index([ownerId])\n  @@index([status])\n  @@map(\"identities\")\n}\n\nmodel PipelineEvent {\n  id         String   @id @default(uuid()) @db.Uuid\n  taskId     String   @db.Uuid\n  fromStatus String\n  toStatus   String\n  actor      String\n  actorId    String?  @db.Uuid\n  reason     String?\n  metadata   Json?\n  createdAt  DateTime @default(now())\n\n  @@index([taskId])\n  @@index([toStatus, actor])\n  @@map(\"pipeline_events\")\n}\n\nmodel WorkflowTemplate {\n  id           String        @id @default(uuid()) @db.Uuid\n  name         String        @unique\n  displayName  String\n  description  String\n  steps        Json\n  isActive     Boolean       @default(true)\n  createdAt    DateTime      @default(now())\n  updatedAt    DateTime      @updatedAt\n  requirements Requirement[]\n\n  @@index([isActive])\n  @@map(\"workflow_templates\")\n}\n\nmodel WorkflowTransition {\n  id            String      @id @default(uuid()) @db.Uuid\n  requirementId String      @db.Uuid\n  fromStep      String\n  toStep        String\n  action        String\n  actorId       String?     @db.Uuid\n  actorName     String\n  actorRole     String\n  comment       String?\n  metadata      Json?\n  createdAt     DateTime    @default(now())\n  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)\n\n  @@index([requirementId])\n  @@index([fromStep])\n  @@index([createdAt])\n  @@map(\"workflow_transitions\")\n}\n\nmodel TestEnvLock {\n  id               String   @id @default(\"singleton\")\n  requirementId    String   @db.Uuid\n  requirementTitle String?\n  branch           String?\n  acquiredAt       DateTime @default(now())\n\n  @@map(\"test_env_lock\")\n}\n\nmodel DailyLog {\n  id          String           @id @default(uuid()) @db.Uuid\n  agentId     String           @db.Uuid\n  date        String\n  status      String           @default(\"working\")\n  content     String\n  problems    String?\n  submittedAt DateTime         @default(now())\n  createdAt   DateTime         @default(now())\n  updatedAt   DateTime         @updatedAt\n  agent       MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)\n\n  @@unique([agentId, date])\n  @@index([date])\n  @@index([agentId])\n  @@index([submittedAt])\n  @@map(\"daily_logs\")\n}\n\nmodel Project {\n  id           String        @id @default(uuid()) @db.Uuid\n  name         String        @unique\n  description  String?\n  boundaries   String?\n  status       String        @default(\"active\")\n  createdAt    DateTime      @default(now())\n  featureList  String?\n  ownerId      String?       @db.Uuid\n  updatedAt    DateTime      @updatedAt\n  owner        User?         @relation(\"ProjectOwner\", fields: [ownerId], references: [id])\n  requirements Requirement[] @relation(\"RequirementProject\")\n\n  @@map(\"projects\")\n}\n\nmodel RequirementComment {\n  id            String               @id @default(uuid()) @db.Uuid\n  requirementId String               @db.Uuid\n  parentId      String?              @db.Uuid\n  content       String\n  authorId      String               @db.Uuid\n  type          String               @default(\"discussion\")\n  status        String               @default(\"open\")\n  mentions      String[]             @default([])\n  createdAt     DateTime             @default(now())\n  updatedAt     DateTime             @updatedAt\n  author        User                 @relation(\"CommentAuthor\", fields: [authorId], references: [id])\n  parent        RequirementComment?  @relation(\"CommentReplies\", fields: [parentId], references: [id], onDelete: Cascade)\n  replies       RequirementComment[] @relation(\"CommentReplies\")\n  requirement   Requirement          @relation(\"CommentRequirement\", fields: [requirementId], references: [id], onDelete: Cascade)\n\n  @@index([requirementId])\n  @@index([authorId])\n  @@index([parentId])\n  @@index([status])\n  @@map(\"requirement_comments\")\n}\n\nenum UserRole {\n  admin\n  requester\n  developer\n  agent\n  cto_agent\n}\n\nenum InternalRole {\n  cto\n  pm\n  backend_developer\n  frontend_developer\n  mobile_developer\n  miniapp_developer\n  game_developer\n  tester\n  security\n  ops\n  qa\n  architect\n}\n\nenum RequirementPriority {\n  P0\n  P1\n  P2\n  P3\n}\n\nenum RequirementStatus {\n  pending\n  approved\n  rejected\n  in_progress @map(\"in-progress\")\n  testing\n  review\n  deploying\n  done\n  clarifying  @map(\"clarifying\")\n  draft\n  abandoned\n}\n\nenum RequirementType {\n  FEATURE\n  BUGFIX\n  POSTMORTEM\n  INFRA\n  SECURITY\n}\n\nenum TaskStatus {\n  todo\n  in_progress @map(\"in-progress\")\n  done\n}\n\nenum ReportType {\n  DEV_SELF_CHECK\n  SECURITY_REVIEW\n  TEST_REPORT\n  CTO_REVIEW\n  DEPLOY_CONFIRM\n  POSTMORTEM\n  TEST_DEPLOY_CONFIRM\n  MERGE_REPORT\n  ARCH_DESIGN\n  ARCH_REVIEW\n}\n\nenum ReportStatus {\n  pending\n  approved\n  rejected\n  changes_requested\n}\n\nenum MarketplaceAgentStatus {\n  active\n  inactive\n  maintenance\n}\n\nenum MarketplaceTaskStatus {\n  pending\n  processing\n  completed\n  failed\n  cancelled\n}\n\nenum MarketplacePriority {\n  low\n  normal\n  high\n  urgent\n}\n\nenum DeliverableType {\n  text\n  image\n  document\n  url\n  file\n}\n\nenum ServiceStatus {\n  online\n  offline\n  maintenance\n  unknown\n}\n\nenum GoalStatus {\n  active\n  paused\n  archived\n}\n\nenum PipelineName {\n  content\n  parenting\n  investment\n  health\n  planning\n  lifestyle\n  devops\n  education\n  business\n  cross_cutting @map(\"cross-cutting\")\n}\n\nenum OkrRole {\n  okr_admin    @map(\"okr_admin\")\n  okr_reviewer @map(\"okr_reviewer\")\n  okr_member   @map(\"okr_member\")\n  okr_owner    @map(\"okr_owner\")\n}\n\nenum GoalLayer {\n  mainline\n  explore\n  life\n  infra\n}\n\nenum MonthlyGoalStatus {\n  not_started\n  in_progress\n  done\n}\n\nenum WeeklyReportStatus {\n  draft\n  submitted\n  reviewed\n  approved\n  changes_requested\n}\n\nenum PostmortemStatus {\n  pending\n  implemented\n  verified\n}\n\nenum EntityType {\n  human\n  agent\n}\n","size":23146}