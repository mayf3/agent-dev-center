/* pages/requirement-submit/index.wxss */
.page { padding: 24rpx; padding-bottom: 160rpx; }
.submit-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 20rpx; padding: 24rpx 28rpx; background: #fff; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.04); }
.submit-bar button { flex: 1; padding: 20rpx; font-size: 28rpx; }
.submit-btn { width: auto; }
.btn-cancel-btn { background: #f5f5f5; color: #666; border: none; border-radius: 12rpx; text-align: center; }
.btn-cancel-btn::after { border: none; }
