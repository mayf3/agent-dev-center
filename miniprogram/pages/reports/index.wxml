<!-- pages/reports/index.wxml -->
<view class="page">
  <view class="page-head">
    <text class="page-title">验收报告</text>
    <text style="font-size:24rpx;color:#999;">已完成需求的验收记录</text>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{reports.length === 0}}" class="empty-state">
    <view class="empty-icon">📊</view>
    <view class="empty-text">暂无验收报告</view>
  </view>

  <view wx:else style="padding:0 24rpx;">
    <view class="list-item" wx:for="{{reports}}" wx:key="id"
      data-rid="{{item.requirementId}}" bindtap="goToDetail">
      <view class="item-title">{{item.title || '验收报告'}}</view>
      <view class="item-meta">
        <view class="meta-item">{{item.requirementTitle}}</view>
      </view>
      <view class="item-meta">
        <view class="meta-item">{{item.createdAt}}</view>
      </view>
    </view>
  </view>
</view>
