generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  requester
  developer
  agent
  cto_agent
}

enum InternalRole {
  cto
  pm
  developer
  backend_developer
  frontend_developer
  mobile_developer
  miniapp_developer
  game_developer
  tester
  security
  ops
  qa
}

enum RequirementPriority {
  P0
  P1
  P2
  P3
}

enum RequirementStatus {
  pending
  clarifying  @map("clarifying") // PM 跟需求方澄清中
  approved
  rejected
  in_progress @map("in-progress")
  testing
  review
  deploying
  done
}

enum RequirementType {
  FEATURE
  BUGFIX
  POSTMORTEM
  INFRA
  SECURITY
}

enum TaskStatus {
  todo
  in_progress @map("in-progress")
  done
}

enum ReportType {
  DEV_SELF_CHECK
  SECURITY_REVIEW
  TEST_REPORT
  CTO_REVIEW
  TEST_DEPLOY_CONFIRM
  DEPLOY_CONFIRM
  POSTMORTEM
  MERGE_REPORT
}

enum ReportStatus {
  pending
  approved
  rejected
  changes_requested
}

model User {
  id                 String        @id @default(uuid()) @db.Uuid
  name               String
  email              String        @unique
  password           String
  role               UserRole      @default(requester)
  internalRole       InternalRole? @map("internal_role")
  roles              String[]      @default([]) @map("roles")
  okrRole            OkrRole       @default(okr_member) @map("okr_role")
  // SSO Agent fields
  agentId            String?       @unique
  permissions        Json          @default("[]")
  // Profile fields
  bio                String?
  phone              String?
  avatar             String?
  department         String?
  title              String? // job title, e.g. "高级工程师"
  // HR management fields
  employeeNo         String?       @unique
  onboardingDate     DateTime?
  managerId          String?       @db.Uuid
  mustChangePassword Boolean       @default(true) @map("must_change_password")
  enabled            Boolean       @default(true)
  // Password tracking
  passwordChangedAt  DateTime?     @map("password_changed_at")
  lastLoginAt        DateTime?     @map("last_login_at")
  manager            User?         @relation("UserManager", fields: [managerId], references: [id])
  directReports      User[]        @relation("UserManager")

  createdAt DateTime @default(now())

  requestedRequirements Requirement[]         @relation("RequesterRequirements")
  assignedRequirements  Requirement[]         @relation("AssigneeRequirements")
  requirementRevisions  RequirementRevision[] @relation("RequirementRevisionOperator")
  submittedReports      RequirementReport[]   @relation("ReportSubmitter")
  marketplaceAgents     MarketplaceAgent[]    @relation("MarketplaceAgentOwner")
  linkedAgent           MarketplaceAgent?     @relation("AgentUserLink")
  marketplaceTasks      MarketplaceTask[]     @relation("MarketplaceRequester")
  ownedProjects         Project[]             @relation("ProjectOwner")
  comments              RequirementComment[]  @relation("CommentAuthor")

  @@index([lastLoginAt])
  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  targetType String
  targetId   String   @db.Uuid
  actorId    String   @db.Uuid
  actorName  String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([actorId])
  @@map("audit_logs")
}

model PasswordPolicy {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @unique @default("default")
  minLength            Int      @default(8)
  requireUppercase     Boolean  @default(true) @map("require_uppercase")
  requireLowercase     Boolean  @default(true) @map("require_lowercase")
  requireNumber        Boolean  @default(true) @map("require_number")
  requireSpecial       Boolean  @default(false) @map("require_special")
  expiresInDays        Int?     @map("expires_in_days") // null = never expire
  forceChangeCycleDays Int?     @map("force_change_cycle_days") // null = no forced change cycle
  isDefault            Boolean  @default(true) @map("is_default")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("password_policies")
}

model Requirement {
  id                  String                @id @default(uuid()) @db.Uuid
  title               String
  description         String                @db.Text
  priority            RequirementPriority   @default(P2)
  requester           String
  requesterId         String?               @db.Uuid
  department          String
  assignee            String?
  assigneeId          String?               @db.Uuid
  pmApprovedAt        DateTime?             @map("pm_approved_at")
  pmApprovedBy        String?               @map("pm_approved_by")
  dueDate             DateTime?
  attachment          String?
  rejectReason        String?               @db.Text
  notes               String?               @db.Text
  type                RequirementType       @default(FEATURE)
  tags                String[]              @default([])
  gitHash             String?
  repoPath            String?             // 4397e6a9: 代码仓库本地路径
  branch              String?             // 4397e6a9: Git 分支名
  deployVersion       String?
  dependsOnIds        String[]              @default([]) @map("depends_on_ids")
  blockedBy           String[]              @default([]) @map("blocked_by")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tasks               Task[]
  revisions           RequirementRevision[]
  reports             RequirementReport[]
  serviceLinks        ServiceRequirement[]
  postmortems         Postmortem[]
  workflowTransitions WorkflowTransition[]

  // Workflow engine fields
  workflowId  String?           @db.Uuid
  workflow    WorkflowTemplate? @relation(fields: [workflowId], references: [id])
  currentStep String?

  requesterUser User? @relation("RequesterRequirements", fields: [requesterId], references: [id])
  assigneeUser  User? @relation("AssigneeRequirements", fields: [assigneeId], references: [id])

  comments RequirementComment[] @relation("CommentRequirement")

  @@index([currentStep])
  @@index([priority])
  @@index([type])
  @@index([requester])
  @@index([requesterId])
  @@index([assignee])
  @@index([assigneeId])
  @@map("requirements")
}

model Task {
  id            String      @id @default(uuid()) @db.Uuid
  requirementId String      @db.Uuid
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  title         String
  description   String      @db.Text
  agentType     String
  status        TaskStatus  @default(todo)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([requirementId])
  @@index([status])
  @@index([agentType])
  @@map("tasks")
}

model RequirementRevision {
  id            String              @id @default(uuid()) @db.Uuid
  requirementId String              @db.Uuid
  requirement   Requirement         @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  title         String
  description   String              @db.Text
  priority      RequirementPriority
  status        RequirementStatus
  requester     String
  department    String
  assignee      String?
  dueDate       DateTime?
  attachment    String?
  revisionNote  String?             @db.Text
  operatorId    String?             @db.Uuid
  operator      User?               @relation("RequirementRevisionOperator", fields: [operatorId], references: [id])
  createdAt     DateTime            @default(now())

  @@index([requirementId])
  @@index([createdAt])
  @@map("requirement_revisions")
}

model RequirementReport {
  id              String       @id @default(uuid()) @db.Uuid
  requirementId   String       @db.Uuid
  requirement     Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  reportType      ReportType
  content         Json
  submittedBy     String
  submittedById   String?      @db.Uuid
  submittedByUser User?        @relation("ReportSubmitter", fields: [submittedById], references: [id])
  status          ReportStatus @default(pending)
  qaReviewedAt    DateTime?    @map("qa_reviewed_at")
  qaReviewedBy    String?      @map("qa_reviewed_by")
  qaBypass        Boolean      @default(false) @map("qa_bypass")
  qaBypassReason  String?      @map("qa_bypass_reason") @db.Text
  qaBypassAt      DateTime?    @map("qa_bypass_at")
  qaBypassBy      String?      @map("qa_bypass_by")
  reviewComment   String?      @db.Text
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // 9da94ac1: 绑定工作流步骤，同一需求同步骤同类型只能有一份报告
  workflowStep    String?      @map("workflow_step")

  @@index([requirementId])
  @@index([reportType])
  @@index([submittedBy])
  @@index([status])
  @@unique([requirementId, reportType, workflowStep])
  @@map("requirement_reports")
}

model Notification {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  type         String
  title        String
  content      Json
  relatedReqId String?  @db.Uuid
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

enum MarketplaceAgentStatus {
  active
  inactive
  maintenance
}

enum MarketplaceTaskStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum MarketplacePriority {
  low
  normal
  high
  urgent
}

enum DeliverableType {
  text
  image
  document
  url
  file
}

model MarketplaceAgent {
  id                 String                 @id @default(uuid()) @db.Uuid
  name               String                 @unique
  displayName        String
  description        String                 @db.Text
  avatar             String?
  capabilities       Json                   @default("[]")
  apiEndpoint        String?
  status             MarketplaceAgentStatus @default(active)
  // Automation fields
  notificationType   String                 @default("polling")
  feishuWebhookUrl   String?
  tags               String[]               @default([])
  lastHeartbeatAt    DateTime?
  agentToken         String?                @unique
  ownerId            String?                @db.Uuid
  owner              User?                  @relation("MarketplaceAgentOwner", fields: [ownerId], references: [id])
  // Direct user link — for /agents/me lookup. Same as ownerId but explicit & indexed.
  userId             String?                @unique @map("user_id") @db.Uuid
  user               User?                  @relation("AgentUserLink", fields: [userId], references: [id])
  // SSO dedup: track which OpenClaw agent this maps to
  openclawAgentId    String? // e.g. "education-agent" — the OpenClaw agentId
  registrationSource String? // "seed" | "sso" | "manual"
  registrationGroup  String? // e.g. "workspace-oc_xxx" — the OpenClaw group/session
  mergedInto         String?                @db.Uuid // if merged, points to the surviving agent ID
  mergedAt           DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  tasks         MarketplaceTask[]
  accessTokens  AgentAccessToken[]
  goalCard      AgentGoalCard?
  weeklyReports WeeklyReport[]
  dailyLogs     DailyLog[]

  @@index([status])
  @@index([ownerId])
  @@index([userId])
  @@map("marketplace_agents")
}

model MarketplaceTask {
  id              String                @id @default(uuid()) @db.Uuid
  agentId         String                @db.Uuid
  agent           MarketplaceAgent      @relation(fields: [agentId], references: [id])
  requesterId     String?               @db.Uuid
  requester       User?                 @relation("MarketplaceRequester", fields: [requesterId], references: [id])
  requesterName   String
  title           String
  description     String                @db.Text
  input           Json?
  priority        MarketplacePriority   @default(normal)
  status          MarketplaceTaskStatus @default(pending)
  deadline        DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  errorMsg        String?               @db.Text
  // Automation fields
  notifiedAt      DateTime?
  executionTimeMs Int?
  tokensUsed      Int?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  deliverables MarketplaceDeliverable[]

  @@index([agentId])
  @@index([status])
  @@index([requesterId])
  @@map("marketplace_tasks")
}

model MarketplaceDeliverable {
  id        String          @id @default(uuid()) @db.Uuid
  taskId    String          @db.Uuid
  task      MarketplaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      DeliverableType
  title     String?
  content   String          @db.Text
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([taskId])
  @@map("marketplace_deliverables")
}

// ─── Agent Access Token ─────────────────────────────────────────

model AgentAccessToken {
  id         String           @id @default(uuid()) @db.Uuid
  agentId    String           @db.Uuid
  agent      MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  token      String           @unique
  name       String           @default("default")
  lastUsedAt DateTime?
  createdAt  DateTime         @default(now())
  expiresAt  DateTime?

  @@index([agentId])
  @@index([token])
  @@map("agent_access_tokens")
}

// ─── Service Registry ───────────────────────────────────────────

enum ServiceStatus {
  online
  offline
  maintenance
  unknown
}

model Service {
  id             String        @id @default(uuid()) @db.Uuid
  name           String        @unique // 机器标识 e.g. "agent-dev-center-backend"
  displayName    String // 显示名 e.g. "Agent Dev Center 后端"
  description    String        @db.Text
  port           Int? // 本地端口
  localUrl       String? // 本地地址
  remoteUrl      String? // 远程地址
  techStack      String[]      @default([]) // ["Node.js", "Express", "PostgreSQL"]
  owner          String? // 负责 Agent
  gitRepo        String? // Git 仓库路径
  database       String? // 使用的数据库
  status         ServiceStatus @default(unknown)
  version        String? // 最新部署版本
  lastDeployedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // 关联需求
  requirements ServiceRequirement[]

  @@index([status])
  @@index([owner])
  @@map("services")
}

model ServiceRequirement {
  id            String   @id @default(uuid()) @db.Uuid
  serviceId     String   @db.Uuid
  requirementId String   @db.Uuid
  relationType  String   @default("related") // related | primary | secondary
  createdAt     DateTime @default(now())

  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([serviceId, requirementId])
  @@index([serviceId])
  @@index([requirementId])
  @@map("service_requirements")
}

// ─── Operations Platform ───────────────────────────────────────

enum CustomerStatus {
  active
  inactive
  lead
  churned
}

enum OrderStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
}

enum RevenueType {
  one_time
  recurring
  refund
}

model Customer {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  email     String?
  phone     String?
  source    String?
  status    CustomerStatus @default(lead)
  notes     String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  orders    Order[]

  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("customers")
}

model Order {
  id          String          @id @default(uuid()) @db.Uuid
  customerId  String          @db.Uuid
  customer    Customer        @relation(fields: [customerId], references: [id])
  agentId     String?         @db.Uuid
  serviceType String
  amount      Decimal         @db.Decimal(10, 2)
  status      OrderStatus     @default(pending)
  description String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  revenues    RevenueRecord[]

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([serviceType])
  @@index([createdAt])
  @@map("orders")
}

model RevenueRecord {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @db.Uuid
  order     Order       @relation(fields: [orderId], references: [id])
  agentId   String?     @db.Uuid
  amount    Decimal     @db.Decimal(10, 2)
  type      RevenueType @default(one_time)
  month     String?
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@index([agentId])
  @@index([type])
  @@index([month])
  @@index([createdAt])
  @@map("revenue_records")
}

// ─── Agent Goal Card ─────────────────────────────────────────

enum GoalStatus {
  active
  paused
  archived
}

enum PipelineName {
  content
  parenting
  investment
  health
  planning
  lifestyle
  devops
  education
  business
  cross_cutting @map("cross-cutting")
}

enum OkrRole {
  okr_admin    @map("okr_admin")
  okr_reviewer @map("okr_reviewer")
  okr_member   @map("okr_member")
  okr_owner    @map("okr_owner")
}

enum GoalLayer {
  mainline
  explore
  life
  infra
}

enum MonthlyGoalStatus {
  not_started
  in_progress
  done
}

model AgentGoalCard {
  id      String           @id @default(uuid()) @db.Uuid
  agentId String           @unique @db.Uuid
  agent   MarketplaceAgent @relation(fields: [agentId], references: [id])

  // Pipeline
  pipeline           PipelineName
  layer              GoalLayer    @default(mainline)
  upstreamAgentIds   String[]     @default([])
  downstreamAgentIds String[]     @default([])

  // Goals
  longTermDirection String @db.Text
  monthlyGoals      Json   @default("[]") // [{month:"2026-05", goals:[{text:string, status:MonthlyGoalStatus}]}]
  selfCheckCriteria String @db.Text

  // Push tracking
  pushedMonths String[] @default([]) // 已推送的月份，用于去重

  // Status
  status GoalStatus @default(active)

  // Review
  lastReviewedAt DateTime?
  lastReviewedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions GoalRevision[]

  @@index([pipeline])
  @@index([status])
  @@map("agent_goal_cards")
}

model GoalRevision {
  id         String        @id @default(uuid()) @db.Uuid
  goalCardId String        @db.Uuid
  goalCard   AgentGoalCard @relation(fields: [goalCardId], references: [id], onDelete: Cascade)

  longTermDirection String       @db.Text
  monthlyGoals      Json
  selfCheckCriteria String       @db.Text
  pipeline          PipelineName

  changeNote  String   @db.Text
  changedBy   String
  changedById String?  @db.Uuid
  createdAt   DateTime @default(now())

  @@index([goalCardId])
  @@index([createdAt])
  @@map("goal_revisions")
}

// ─── Weekly Report ──────────────────────────────────────────

enum WeeklyReportStatus {
  draft
  submitted
  reviewed
  approved
  changes_requested
}

model WeeklyReport {
  id      String           @id @default(uuid()) @db.Uuid
  agentId String           @db.Uuid
  agent   MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Week identification (e.g. "2026-W21" or "2026-05-19")
  week String

  // Report content
  content      String @db.Text
  summary      String @default("") @db.Text
  nextWeekPlan String @default("") @db.Text
  blockers     String @default("") @db.Text

  // Submission
  submittedBy String    @default("")
  submittedAt DateTime?

  // Review
  status        WeeklyReportStatus @default(draft)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, week])
  @@index([agentId])
  @@index([week])
  @@index([status])
  @@map("weekly_reports")
}

// ─── Postmortem Report ──────────────────────────────────────

enum PostmortemStatus {
  pending
  implemented
  verified
}

model Postmortem {
  id            String       @id @default(uuid()) @db.Uuid
  requirementId String?      @db.Uuid
  requirement   Requirement? @relation(fields: [requirementId], references: [id])

  title              String
  phenomenon         String           @db.Text
  rootCause          String           @db.Text
  whyExistingProcess String           @db.Text
  longTermPrinciple  String           @db.Text
  preventionMeasures String           @db.Text
  responsiblePerson  String
  status             PostmortemStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([responsiblePerson])
  @@index([requirementId])
  @@map("postmortems")
}

// ─── Unified Identity (Human + Agent) ─────────────────────

enum EntityType {
  human
  agent
}

model Identity {
  id String @id @default(uuid()) @db.Uuid

  // Type
  type EntityType

  // ── Common fields ──
  displayName       String
  avatar            String?
  description       String        @db.Text
  longTermDirection String        @db.Text
  // JSON schema: Array<{month, goal, krs: [{text, progress, status}], status}>
  monthlyGoals      Json          @default("[]")
  capabilities      Json          @default("[]")
  pipeline          PipelineName?
  layer             GoalLayer?

  // ── Agent-specific ──
  agentId   String? @unique // references marketplace_agents.id
  ownerId   String? @map("owner_id") // references users.id (no FK)
  agentType String?

  // ── Human-specific ──
  userId String? @unique // references users.id

  // ── Meta ──
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([pipeline])
  @@index([ownerId])
  @@index([status])
  @@map("identities")
}

// ─── Pipeline Event Log ─────────────────────────────────────

model PipelineEvent {
  id         String   @id @default(uuid()) @db.Uuid
  taskId     String   @db.Uuid
  fromStatus String
  toStatus   String
  actor      String // "system", "agent", "user"
  actorId    String?  @db.Uuid
  reason     String?  @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([taskId])
  @@index([toStatus, actor])
  @@map("pipeline_events")
}

// ─── Workflow Engine ──────────────────────────────────────

model WorkflowTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique // "backend-dev", "frontend-dev", "ops-deploy", "hotfix"
  displayName String // "后端开发", "前端开发", "运维部署", "紧急修复"
  description String   @db.Text
  steps       Json // JSONB: [{name, displayName, role, requiredReports[], autoAdvance}]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirements Requirement[]

  @@index([isActive])
  @@map("workflow_templates")
}

model WorkflowTransition {
  id            String      @id @default(uuid()) @db.Uuid
  requirementId String      @db.Uuid
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  fromStep      String // step name
  toStep        String // step name
  action        String // "advance" | "reject" | "assign-workflow"
  actorId       String?     @db.Uuid
  actorName     String
  actorRole     String
  comment       String?     @db.Text
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([requirementId])
  @@index([fromStep])
  @@index([createdAt])
  @@map("workflow_transitions")
}

// ─── Daily Log ──────────────────────────────────────────

model DailyLog {
  id          String   @id @default(uuid()) @db.Uuid
  agentId     String   @db.Uuid
  agent       MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  date        String   // YYYY-MM-DD
  status      String   @default("working") // working | completed | blocked | idle
  content     String   @db.Text
  problems    String?  @db.Text
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([agentId, date])
  @@index([date])
  @@index([agentId])
  @@index([submittedAt])
  @@map("daily_logs")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?  @db.Text
  boundaries  String?  @db.Text  // 产品边界
  featureList String?  @db.Text  // 功能清单
  status      String   @default("active")
  ownerId     String?  @db.Uuid
  owner       User?    @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

// 488bb834: 协作评论系统
model RequirementComment {
  id             String   @id @default(uuid()) @db.Uuid
  requirementId  String   @db.Uuid
  requirement    Requirement @relation("CommentRequirement", fields: [requirementId], references: [id], onDelete: Cascade)

  // Thread support
  parentId       String?  @db.Uuid
  parent         RequirementComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        RequirementComment[] @relation("CommentReplies")

  // Content
  content        String   @db.Text
  authorId       String   @db.Uuid
  author         User     @relation("CommentAuthor", fields: [authorId], references: [id])

  // Metadata
  type           String   @default("discussion")  // discussion | review | status_change | system
  status         String   @default("open")         // open | resolved | archived
  mentions       String[] @default([])              // @mentioned agent IDs

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([requirementId])
  @@index([authorId])
  @@index([parentId])
  @@index([status])
  @@map("requirement_comments")
}
