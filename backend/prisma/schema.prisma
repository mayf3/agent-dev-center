generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  requester
  developer
  agent
  cto_agent
}


enum InternalRole {
  cto
  pm
  developer
  tester
  security
  ops
  qa
}
enum RequirementPriority {
  P0
  P1
  P2
  P3
}

enum RequirementStatus {
  pending
  clarifying  @map("clarifying")   // PM 跟需求方澄清中
  approved
  rejected
  in_progress @map("in-progress")
  testing
  review
  deploying
  done
}

enum TaskStatus {
  todo
  in_progress @map("in-progress")
  done
}

enum ReportType {
  DEV_SELF_CHECK
  SECURITY_REVIEW
  TEST_REPORT
  CTO_REVIEW
  DEPLOY_CONFIRM
  POSTMORTEM
}

enum ReportStatus {
  pending
  approved
  rejected
  changes_requested
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  role          UserRole    @default(requester)
  internalRole  InternalRole?  @map("internal_role")
  // SSO Agent fields
  agentId     String?  @unique
  permissions Json     @default("[]")
  createdAt DateTime @default(now())

  requestedRequirements Requirement[]         @relation("RequesterRequirements")
  assignedRequirements  Requirement[]         @relation("AssigneeRequirements")
  requirementRevisions  RequirementRevision[] @relation("RequirementRevisionOperator")
  submittedReports      RequirementReport[]   @relation("ReportSubmitter")
  marketplaceAgents     MarketplaceAgent[]    @relation("MarketplaceAgentOwner")
  marketplaceTasks      MarketplaceTask[]     @relation("MarketplaceRequester")

  @@map("users")
}

model Requirement {
  id            String                @id @default(uuid()) @db.Uuid
  title         String
  description   String                @db.Text
  priority      RequirementPriority   @default(P2)
  status        RequirementStatus     @default(pending)
  requester     String
  requesterId   String?               @db.Uuid
  department    String
  assignee      String?
  assigneeId    String?               @db.Uuid
  pmApprovedAt  DateTime?  @map("pm_approved_at")
  pmApprovedBy  String?  @map("pm_approved_by")
  dueDate       DateTime?
  attachment    String?
  rejectReason  String?               @db.Text
  gitHash       String?
  deployVersion String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  tasks         Task[]
  revisions     RequirementRevision[]
  reports       RequirementReport[]
  serviceLinks  ServiceRequirement[]
  postmortems   Postmortem[]

  requesterUser User? @relation("RequesterRequirements", fields: [requesterId], references: [id])
  assigneeUser  User? @relation("AssigneeRequirements", fields: [assigneeId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([requester])
  @@index([requesterId])
  @@index([assignee])
  @@index([assigneeId])
  @@map("requirements")
}

model Task {
  id            String      @id @default(uuid()) @db.Uuid
  requirementId String      @db.Uuid
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  title         String
  description   String      @db.Text
  agentType     String
  status        TaskStatus  @default(todo)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([requirementId])
  @@index([status])
  @@index([agentType])
  @@map("tasks")
}

model RequirementRevision {
  id            String              @id @default(uuid()) @db.Uuid
  requirementId String              @db.Uuid
  requirement   Requirement         @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  title         String
  description   String              @db.Text
  priority      RequirementPriority
  status        RequirementStatus
  requester     String
  department    String
  assignee      String?
  dueDate       DateTime?
  attachment    String?
  revisionNote  String?             @db.Text
  operatorId    String?             @db.Uuid
  operator      User?               @relation("RequirementRevisionOperator", fields: [operatorId], references: [id])
  createdAt     DateTime            @default(now())

  @@index([requirementId])
  @@index([createdAt])
  @@map("requirement_revisions")
}

model RequirementReport {
  id              String       @id @default(uuid()) @db.Uuid
  requirementId   String       @db.Uuid
  requirement     Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  reportType      ReportType
  content         Json
  submittedBy     String
  submittedById   String?      @db.Uuid
  submittedByUser User?        @relation("ReportSubmitter", fields: [submittedById], references: [id])
  status          ReportStatus @default(pending)
  qaReviewedAt    DateTime?  @map("qa_reviewed_at")
  qaReviewedBy    String?  @map("qa_reviewed_by")
  reviewComment   String?      @db.Text
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([requirementId])
  @@index([reportType])
  @@index([submittedBy])
  @@index([status])
  @@map("requirement_reports")
}

model Notification {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  type         String
  title        String
  content      Json
  relatedReqId String?  @db.Uuid
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

enum MarketplaceAgentStatus {
  active
  inactive
  maintenance
}

enum MarketplaceTaskStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum MarketplacePriority {
  low
  normal
  high
  urgent
}

enum DeliverableType {
  text
  image
  document
  url
  file
}

model MarketplaceAgent {
  id           String                 @id @default(uuid()) @db.Uuid
  name         String                 @unique
  displayName  String
  description  String                 @db.Text
  avatar       String?
  capabilities Json                   @default("[]")
  apiEndpoint  String?
  status       MarketplaceAgentStatus @default(active)
  // Automation fields
  notificationType  String            @default("polling")
  feishuWebhookUrl  String?
  tags              String[]          @default([])
  lastHeartbeatAt   DateTime?
  agentToken        String?           @unique
  ownerId      String?                @db.Uuid
  owner        User?                  @relation("MarketplaceAgentOwner", fields: [ownerId], references: [id])
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  tasks MarketplaceTask[]
  accessTokens AgentAccessToken[]
  goalCard     AgentGoalCard?
  weeklyReports WeeklyReport[]

  @@index([status])
  @@map("marketplace_agents")
}

model MarketplaceTask {
  id            String                @id @default(uuid()) @db.Uuid
  agentId       String                @db.Uuid
  agent         MarketplaceAgent      @relation(fields: [agentId], references: [id])
  requesterId   String?               @db.Uuid
  requester     User?                 @relation("MarketplaceRequester", fields: [requesterId], references: [id])
  requesterName String
  title         String
  description   String                @db.Text
  input         Json?
  priority      MarketplacePriority   @default(normal)
  status        MarketplaceTaskStatus @default(pending)
  deadline      DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  errorMsg      String?               @db.Text
  // Automation fields
  notifiedAt    DateTime?
  executionTimeMs Int?
  tokensUsed    Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  deliverables MarketplaceDeliverable[]

  @@index([agentId])
  @@index([status])
  @@index([requesterId])
  @@map("marketplace_tasks")
}

model MarketplaceDeliverable {
  id        String          @id @default(uuid()) @db.Uuid
  taskId    String          @db.Uuid
  task      MarketplaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      DeliverableType
  title     String?
  content   String          @db.Text
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([taskId])
  @@map("marketplace_deliverables")
}

// ─── Agent Access Token ─────────────────────────────────────────

model AgentAccessToken {
  id        String   @id @default(uuid()) @db.Uuid
  agentId   String   @db.Uuid
  agent     MarketplaceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  token     String   @unique
  name      String   @default("default")
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([agentId])
  @@index([token])
  @@map("agent_access_tokens")
}

// ─── Service Registry ───────────────────────────────────────────

enum ServiceStatus {
  online
  offline
  maintenance
  unknown
}

model Service {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @unique                       // 机器标识 e.g. "agent-dev-center-backend"
  displayName   String                                      // 显示名 e.g. "Agent Dev Center 后端"
  description   String        @db.Text
  port          Int?                                         // 本地端口
  localUrl      String?                                      // 本地地址
  remoteUrl     String?                                      // 远程地址
  techStack     String[]      @default([])                  // ["Node.js", "Express", "PostgreSQL"]
  owner         String?                                      // 负责 Agent
  gitRepo       String?                                      // Git 仓库路径
  database      String?                                      // 使用的数据库
  status        ServiceStatus @default(unknown)
  version       String?                                      // 最新部署版本
  lastDeployedAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // 关联需求
  requirements ServiceRequirement[]

  @@index([status])
  @@index([owner])
  @@map("services")
}

model ServiceRequirement {
  id             String   @id @default(uuid()) @db.Uuid
  serviceId      String   @db.Uuid
  requirementId  String   @db.Uuid
  relationType   String   @default("related")          // related | primary | secondary
  createdAt      DateTime @default(now())

  service      Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  requirement  Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([serviceId, requirementId])
  @@index([serviceId])
  @@index([requirementId])
  @@map("service_requirements")
}

// ─── Agent Goal Card ─────────────────────────────────────────

enum GoalStatus {
  active
  paused
  archived
}

enum PipelineName {
  content
  parenting
  investment
  health
  planning
  lifestyle
  devops
  education
}

enum MonthlyGoalStatus {
  not_started
  in_progress
  done
}

model AgentGoalCard {
  id              String       @id @default(uuid()) @db.Uuid
  agentId         String       @unique @db.Uuid
  agent           MarketplaceAgent @relation(fields: [agentId], references: [id])

  // Pipeline
  pipeline        PipelineName
  upstreamAgentIds String[]    @default([])
  downstreamAgentIds String[]  @default([])

  // Goals
  longTermDirection String     @db.Text
  monthlyGoals    Json         @default("[]")       // [{month:"2026-05", goals:[{text:string, status:MonthlyGoalStatus}]}]
  selfCheckCriteria String     @db.Text

  // Push tracking
  pushedMonths    String[]     @default([])          // 已推送的月份，用于去重

  // Status
  status          GoalStatus   @default(active)

  // Review
  lastReviewedAt  DateTime?
  lastReviewedBy  String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  revisions       GoalRevision[]

  @@index([pipeline])
  @@index([status])
  @@map("agent_goal_cards")
}

model GoalRevision {
  id              String       @id @default(uuid()) @db.Uuid
  goalCardId      String       @db.Uuid
  goalCard        AgentGoalCard @relation(fields: [goalCardId], references: [id], onDelete: Cascade)

  longTermDirection String     @db.Text
  monthlyGoals    Json
  selfCheckCriteria String     @db.Text
  pipeline        PipelineName

  changeNote      String       @db.Text
  changedBy       String
  changedById     String?      @db.Uuid
  createdAt       DateTime     @default(now())

  @@index([goalCardId])
  @@index([createdAt])
  @@map("goal_revisions")
}

// ─── Weekly Report ──────────────────────────────────────────

enum WeeklyReportStatus {
  draft
  submitted
  reviewed
  approved
  changes_requested
}

model WeeklyReport {
  id            String             @id @default(uuid()) @db.Uuid
  agentId       String             @db.Uuid
  agent         MarketplaceAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Week identification (e.g. "2026-W21" or "2026-05-19")
  week          String

  // Report content
  content       String             @db.Text
  summary       String             @default("") @db.Text
  nextWeekPlan  String             @default("") @db.Text
  blockers      String             @default("") @db.Text

  // Submission
  submittedBy   String             @default("")
  submittedAt   DateTime?

  // Review
  status        WeeklyReportStatus @default(draft)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?            @db.Text

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([agentId, week])
  @@index([agentId])
  @@index([week])
  @@index([status])
  @@map("weekly_reports")
}

// ─── Postmortem Report ──────────────────────────────────────

enum PostmortemStatus {
  pending
  implemented
  verified
}

model Postmortem {
  id              String           @id @default(uuid()) @db.Uuid
  requirementId   String?          @db.Uuid
  requirement     Requirement?     @relation(fields: [requirementId], references: [id])

  title           String
  phenomenon      String           @db.Text
  rootCause       String           @db.Text
  whyExistingProcess String        @db.Text
  longTermPrinciple String         @db.Text
  preventionMeasures String        @db.Text
  responsiblePerson String
  status          PostmortemStatus @default(pending)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([responsiblePerson])
  @@index([requirementId])
  @@map("postmortems")
}
