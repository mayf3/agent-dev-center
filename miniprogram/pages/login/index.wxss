/* pages/login/index.wxss */
.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.login-logo {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  width: 100%;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
}

.error-msg {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: #fff2f0;
  border-radius: 8rpx;
}

.login-btn {
  margin-top: 16rpx;
  width: 100%;
  padding: 24rpx;
  font-size: 32rpx;
}

.login-footer {
  margin-top: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
